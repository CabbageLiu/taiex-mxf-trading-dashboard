DATABASE_URL=postgresql+asyncpg://taiex:taiex@localhost:5432/taiex
DISCORD_WEBHOOK_URL=
N8N_WEBHOOK_URL=
ALERT_SECRET=
TIMEZONE=Asia/Taipei
SYMBOL_DISPLAY=MXF

# Shioaji (SinoPac) — live tick feed + historical backfill.
# Quote-only usage: CA activation NOT required. CA env vars kept here for
# future order-placement work but unused by the current ingest path.
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=
SHIOAJI_CA_CERT_PATH=
SHIOAJI_CA_PASSWORD=
SHIOAJI_PERSON_ID=
# Rolling near-month TXF alias. SinoPac auto-rolls on expiry. DB rows are
# still labelled SYMBOL_DISPLAY (MXF) since TXF/MXF track the same index.
SHIOAJI_CONTRACT=TXFR1
# Set true to hit Shioaji's simulation endpoint for staging tests.
SHIOAJI_SIMULATION=false
# Bound on the in-process tick queue (callback thread → asyncio consumer).
# Oldest tick dropped on overflow with a warning log.
SHIOAJI_QUEUE_MAXSIZE=10000
# Cool-down between login retries (daily cap = 1000 / personId).
SHIOAJI_LOGIN_COOLDOWN_SEC=30

# Feed-health watchdog — forces a full Shioaji re-login when ticks stop during
# an open market session (the SDK can get stuck "down" with auto-reconnect
# failing silently). FEED_WATCHDOG_ENABLED=false disables it.
FEED_WATCHDOG_ENABLED=true
# Tick silence (s) during a session before forcing a reconnect.
FEED_STALE_SECONDS=90
# Upper bound on the exponential backoff between forced reconnects.
FEED_RECONNECT_BACKOFF_MAX_SEC=300
# Hard cap on forced reconnects per session (protects the 1000/day login cap).
FEED_MAX_RECONNECTS_PER_SESSION=10

# Historical backfill — TXFR1 via api.ticks(contract, date).
# BACKFILL_ON_STARTUP_DAYS: scan-and-fill last N days on each backend boot
#   (0 = disabled). Today is always skipped.
# BACKFILL_MIN_TICKS_PER_DAY: market day with fewer ticks than this is
#   considered "missing" and refetched.
BACKFILL_ON_STARTUP_DAYS=7
BACKFILL_MIN_TICKS_PER_DAY=1000

# AI insights (Anthropic Claude Sonnet, V2 strategy analysis page)
# Note: prefixed with TAIEX_ so it does not collide with Claude Code's
# ANTHROPIC_API_KEY when this .env is sourced into a shell.
# TAIEX_ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# INSIGHTS_CACHE_TTL_SECONDS=1800
