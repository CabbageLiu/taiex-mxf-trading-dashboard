FINMIND_TOKEN=
DATABASE_URL=postgresql+asyncpg://taiex:taiex@localhost:5432/taiex
DISCORD_WEBHOOK_URL=
N8N_WEBHOOK_URL=
ALERT_SECRET=
TIMEZONE=Asia/Taipei
SYMBOL_DISPLAY=MXF
SYMBOL_SOURCE=TXF
POLL_INTERVAL_SEC=5

# Historical backfill (V2.5) — TaiwanFuturesTick dataset
# BACKFILL_DATA_ID: futures contract id in FinMind's historical dataset
#   MTX = 小台 (matches SYMBOL_DISPLAY=MXF, ~16k ticks/day)
#   TX  = 大台 (matches live SYMBOL_SOURCE=TXF, ~6k ticks/day)
# BACKFILL_ON_STARTUP_DAYS: scan-and-fill last N days on each backend boot
#   (0 = disabled). Today is always skipped (FinMind updates EOD).
# BACKFILL_MIN_TICKS_PER_DAY: a market day with fewer ticks than this is
#   considered "missing" and refetched.
BACKFILL_DATA_ID=MTX
BACKFILL_ON_STARTUP_DAYS=7
BACKFILL_MIN_TICKS_PER_DAY=1000

# AI insights (Anthropic Claude Sonnet, V2 strategy analysis page)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# INSIGHTS_CACHE_TTL_SECONDS=1800
